# SMTP transport configuration for the `send-email` CLI.
# Copy to `.env` and fill in. The library never reads these — only the CLI does.

SMTP_HOST=smtp.example.com
SMTP_PORT=587
# true for implicit TLS (port 465); defaults to (port === 465) when unset.
SMTP_SECURE=false
SMTP_USER=apikey-or-username
# NEVER pass credentials via a CLI flag — env only.
SMTP_PASS=secret
# Default sender when --from is omitted.
SMTP_FROM=no-reply@example.com
# Default Reply-To when --reply-to is omitted (optional).
SMTP_REPLY_TO=support@example.com

# --- TLS escape hatches (optional) ---
# SNI / certificate hostname override for cert-hostname mismatches.
SMTP_SERVERNAME=
# Set false only as an insecure last resort.
SMTP_TLS_REJECT_UNAUTHORIZED=true

# --- Timeouts in milliseconds (optional) ---
SMTP_CONNECTION_TIMEOUT_MS=10000
SMTP_SOCKET_TIMEOUT_MS=10000
