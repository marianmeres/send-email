{
  "name": "@marianmeres/send-email",
  "version": "1.0.0",
  "exports": "./src/main.ts",
  "tasks": {
    "test": "deno test -A",
    "test:watch": "deno test -A --watch",
    "npm:build": "deno run -A scripts/build-npm.ts",
    "npm:publish": "deno run -A scripts/build-npm.ts && cd ./.npm-dist && npm publish --access=public",
    "release": "deno run -A jsr:@marianmeres/deno-release",
    "publish": "deno publish && deno task npm:publish",
    "rp": "deno task release -y && deno task publish",
    "rpm": "deno task release minor -y && deno task publish"
  },
  "imports": {
    "@marianmeres/npmbuild": "jsr:@marianmeres/npmbuild@^1.16.0",
    "@std/assert": "jsr:@std/assert@^1.0.19",
    "@std/cli": "jsr:@std/cli@^1.0.30",
    "@std/dotenv": "jsr:@std/dotenv@^0.225.7",
    "@std/path": "jsr:@std/path@^1.1.5",
    "nodemailer": "npm:nodemailer@^9.0.1"
  },
  "fmt": {
    "useTabs": true,
    "lineWidth": 90,
    "indentWidth": 4,
    "proseWrap": "preserve"
  }
}
